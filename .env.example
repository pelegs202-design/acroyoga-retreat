# Database (Neon / Vercel Postgres)
# Get from: Vercel Dashboard -> Storage -> Create Postgres Database -> .env.local tab
# Or: Neon Console -> Connection Details -> Connection string
DATABASE_URL=

# Resend - Email delivery for password reset
# Get from: Resend Dashboard (resend.com) -> API Keys -> Create API Key
RESEND_API_KEY=

# Optional: Custom from-address for password reset emails
# Defaults to: AcroYoga Academy <noreply@acro.academy>
RESEND_FROM_EMAIL=

# App URL (used by Better Auth for absolute URLs and password reset links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth secret - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Green Invoice (Payment + Invoicing)
# Get from: Green Invoice Dashboard -> Settings -> Developer Tools -> API Keys
GI_API_KEY_ID=
GI_API_KEY_SECRET=
# Set to 'true' for sandbox testing, 'false' or omit for production
GI_SANDBOX=true
# Webhook secret — set in GI Dashboard -> Webhooks -> Secret field. Validates incoming webhooks.
GI_WEBHOOK_SECRET=
# WhatsApp group invite link (shown on payment success page, needs NEXT_PUBLIC_ for client components)
NEXT_PUBLIC_CHALLENGE_WA_GROUP_URL=
# Base URL for payment redirect URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
